API_V1_STR="/api/v1"
PROJECT_NAME="ASTRA"
ENVIRONMENT="prod"
BACKEND_CORS_ORIGINS='["https://astra.yourdomain.com"]'

POSTGRES_USER="your_prod_db_user"
POSTGRES_PASSWORD="your_prod_db_password"
POSTGRES_DB="astra_prod"

DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}"
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE_MUST_CHANGE"
JWT_SECRET_KEY="YOUR_JWT_SECRET_KEY_HERE_MUST_CHANGE"
