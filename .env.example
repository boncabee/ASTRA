# ASTRA Production Environment Variables Example
# Copy this file to .env and replace the values with secure secrets.

# ==========================================
# Application Settings
# ==========================================
DOMAIN=example.com
NEXT_PUBLIC_API_URL=https://example.com/api/v1
# In production, LOG_LEVEL should be INFO or WARNING
LOG_LEVEL=INFO
PRIVACY_MODE=true
# Required: activates production security guards (insecure default detection, SQL echo disable)
ENVIRONMENT=prod

# ==========================================
# Database Credentials
# ==========================================
POSTGRES_USER=astra_prod
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=astra
# AsyncPG URL format
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ==========================================
# Security & Auth
# ==========================================
# Generate a secure 32+ character string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_SECURE_JWT_SECRET

# ==========================================
# External Services
# ==========================================
# Required for observability engine / AI insights
GEMINI_API_KEY=
