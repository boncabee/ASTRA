ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different system versions, where
#   pipenv auto-creates Pipfile.lock, it should be ignored.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock style should be checked-in, but not necessarily always
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock files should be checked-in
.pdm-plugins/
.pdm-build/

# PEP 582; project local packages (e.g. pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

