# ASTRA Staging Environment Variables
# This file is used exclusively for the staging deployment.
# NEVER commit this file — it contains real secrets.
# Copy from .env.example and populate all values.

# ==========================================
# Application Settings
# ==========================================
DOMAIN=staging.your-domain.com
NEXT_PUBLIC_API_URL=https://staging.your-domain.com/api/v1
BACKEND_CORS_ORIGINS=["https://staging.your-domain.com"]
LOG_LEVEL=INFO
PRIVACY_MODE=true
# Must remain prod to keep all security guards active on staging
ENVIRONMENT=prod
CERTBOT_EMAIL=admin@your-domain.com

# ==========================================
# Database Credentials (STAGING — separate from production)
# ==========================================
POSTGRES_USER=astra_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING_PASSWORD
POSTGRES_DB=astra_staging
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ==========================================
# Security & Auth (STAGING — must differ from production keys)
# ==========================================
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_STAGING_JWT_SECRET

# ==========================================
# External Services
# ==========================================
GEMINI_API_KEY=

# ==========================================
# Observability
# ==========================================
SLACK_WEBHOOK_URL=
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
